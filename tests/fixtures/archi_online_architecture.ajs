
/*
 * Archi Online Architecture Model Generator
 * File: archi-online-architecture.ajs
 * Purpose: Generate an extensive ArchiMate model of the Archi Online architecture.
 * Target: Archi Online Scripting panel and jArchi-style scripting environments.
 * Style: ES5-compatible JavaScript: var/functions, no module imports, no file-system APIs.
 *
 * Usage:
 * 1. Open Archi Online with a scratch or target model.
 * 2. Import this file into the Scripting panel or paste it into a script.
 * 3. Run it. The script updates/reuses generated elements and relationships, then regenerates generated views.
 * 4. Undo once if the result is not desired; Archi Online batches a script run into one undo step.
 */
(function () {
  var SCRIPT_ID = "thomasrohde.archi-online.architecture";
  var SCRIPT_VERSION = "1.0.0";
  var SOURCE_REPOSITORY = "https://github.com/ThomasRohde/archi-online";
  var REGENERATE_GENERATED_VIEWS = true;
  var GENERATED_AT = new Date().toISOString();

  if (typeof console !== "undefined" && console.clear) {
    console.clear();
  }
  console.log("Generating Archi Online architecture model using " + SCRIPT_ID + " " + SCRIPT_VERSION);

  function valueToString(value) {
    if (value === null || value === undefined) {
      return "";
    }
    if (typeof value === "string") {
      return value;
    }
    if (typeof JSON !== "undefined" && JSON.stringify) {
      return JSON.stringify(value);
    }
    return String(value);
  }

  function setProps(obj, props) {
    var key;
    if (!obj || !props) {
      return obj;
    }
    for (key in props) {
      if (props.hasOwnProperty(key)) {
        obj.prop(key, valueToString(props[key]));
      }
    }
    obj.prop("AO Generated By", SCRIPT_ID);
    obj.prop("AO Generator Version", SCRIPT_VERSION);
    obj.prop("AO Generated At", GENERATED_AT);
    return obj;
  }

  function setCommon(obj, def) {
    if (!obj || !def) {
      return obj;
    }
    if (def.documentation !== undefined) {
      obj.documentation = def.documentation;
    }
    setProps(obj, def.properties || {});
    obj.prop("AO Source Repository", SOURCE_REPOSITORY);
    if (def.key) {
      obj.prop("AO Key", def.key);
    }
    return obj;
  }

  function folderByName(name) {
    return $("folder").filter(function (folder) {
      return folder.name === name;
    }).first();
  }

  var FOLDERS = {
    strategy: folderByName("Strategy"),
    business: folderByName("Business"),
    application: folderByName("Application"),
    technology: folderByName("Technology & Physical") || folderByName("Technology"),
    physical: folderByName("Technology & Physical") || folderByName("Physical"),
    motivation: folderByName("Motivation"),
    implementation: folderByName("Implementation & Migration"),
    other: folderByName("Other"),
    views: folderByName("Views") || folderByName("Diagrams")
  };

  var TYPE_FOLDER = {
    "resource": "strategy", "capability": "strategy", "course-of-action": "strategy", "value-stream": "strategy",
    "business-actor": "business", "business-role": "business", "business-process": "business", "business-service": "business", "business-object": "business",
    "application-component": "application", "application-function": "application", "application-service": "application", "application-interface": "application", "data-object": "application",
    "node": "technology", "device": "technology", "system-software": "technology", "technology-service": "technology", "artifact": "technology", "path": "technology", "communication-network": "technology",
    "stakeholder": "motivation", "driver": "motivation", "assessment": "motivation", "goal": "motivation", "outcome": "motivation", "principle": "motivation", "requirement": "motivation", "constraint": "motivation",
    "work-package": "implementation", "deliverable": "implementation", "plateau": "implementation", "gap": "implementation",
    "grouping": "other", "location": "other"
  };

  function folderForType(type) {
    var folderKey = TYPE_FOLDER[type] || "other";
    return FOLDERS[folderKey];
  }

  function exact(type, name) {
    return $(type).filter(function (obj) {
      return obj.name === name;
    }).first();
  }

  function generatedByKey(selector, key) {
    return $(selector).filter(function (obj) {
      return obj.prop && obj.prop("AO Key") === key;
    }).first();
  }

  function ensureElement(def) {
    var folder = folderForType(def.type);
    var obj = generatedByKey(def.type, def.key) || exact(def.type, def.name);
    if (!obj) {
      obj = model.createElement(def.type, def.name, folder);
      console.log("Created element: " + def.type + " :: " + def.name);
    }
    setCommon(obj, def);
    obj.prop("AO Element Type", def.type);
    return obj;
  }

  function findRelationship(def, source, target) {
    return generatedByKey("relationship", def.key) || $("relationship").filter(function (rel) {
      return rel.name === def.name && rel.source && rel.target && rel.source.id === source.id && rel.target.id === target.id;
    }).first();
  }

  function ensureRelationship(def, elements) {
    var source = elements[def.source];
    var target = elements[def.target];
    var relObj;
    if (!source || !target) {
      console.warn("Skipping relationship with missing endpoint: " + def.key);
      return null;
    }

    relObj = findRelationship(def, source, target);
    if (!relObj) {
      try {
        relObj = model.createRelationship(def.type, def.name, source, target);
      } catch (primaryError) {
        try {
          relObj = model.createRelationship("association-relationship", def.name, source, target);
          relObj.prop("AO Relationship Fallback", "association-relationship");
          relObj.prop("AO Relationship Primary Error", String(primaryError && primaryError.message ? primaryError.message : primaryError));
          console.warn("Used association fallback for " + def.type + " :: " + def.name);
        } catch (fallbackError) {
          console.warn("Skipped relationship " + def.type + " :: " + def.name + " - " + String(fallbackError && fallbackError.message ? fallbackError.message : fallbackError));
          return null;
        }
      }
      console.log("Created relationship: " + def.type + " :: " + def.name + " :: " + source.name + " -> " + target.name);
    }
    setCommon(relObj, def);
    relObj.prop("AO Intended Relationship Type", def.type);
    if (def.accessType && relObj.accessType !== undefined) {
      relObj.accessType = def.accessType;
    }
    if (def.influenceStrength && relObj.influenceStrength !== undefined) {
      relObj.influenceStrength = def.influenceStrength;
    }
    if (def.associationDirected !== undefined && relObj.associationDirected !== undefined) {
      relObj.associationDirected = def.associationDirected;
    }
    return relObj;
  }

  function purgeGeneratedViews(viewNames) {
    var nameMap = {};
    var i;
    for (i = 0; i < viewNames.length; i++) {
      nameMap[viewNames[i]] = true;
    }
    if (!REGENERATE_GENERATED_VIEWS) {
      return;
    }
    $("view").filter(function (view) {
      return view.prop("AO Generated By") === SCRIPT_ID || nameMap[view.name];
    }).each(function (view) {
      console.log("Deleting previously generated view: " + view.name);
      view.delete();
    });
  }

  function createView(name, documentation, properties) {
    var view = model.createArchimateView(name, FOLDERS.views);
    view.documentation = documentation;
    setProps(view, properties || {});
    view.prop("AO View Purpose", documentation);
    return view;
  }

  function setVisualStyle(visual, style) {
    if (!visual || !style) {
      return visual;
    }
    if (style.fillColor !== undefined) {
      visual.fillColor = style.fillColor;
    }
    if (style.lineColor !== undefined) {
      visual.lineColor = style.lineColor;
    }
    if (style.fontColor !== undefined) {
      visual.fontColor = style.fontColor;
    }
    if (style.opacity !== undefined) {
      visual.opacity = style.opacity;
    }
    return visual;
  }

  function addGroup(view, text, x, y, width, height, style) {
    var group = view.createObject("group", x, y, width, height);
    group.name = text;
    group.text = text;
    setVisualStyle(group, style || STYLE.group);
    return group;
  }

  function addNote(view, text, x, y, width, height, style) {
    var note = view.createObject("note", x, y, width, height);
    note.name = text.length > 80 ? text.substring(0, 80) : text;
    note.text = text;
    setVisualStyle(note, style || STYLE.note);
    return note;
  }

  function addNode(viewOrGroup, element, x, y, width, height, style) {
    var visual;
    if (!element) {
      return null;
    }
    try {
      visual = viewOrGroup.add(element, x, y, width, height);
      setVisualStyle(visual, style || {});
      return visual;
    } catch (error) {
      console.warn("Could not add node " + element.name + " - " + String(error && error.message ? error.message : error));
      return null;
    }
  }

  function addConnection(view, relObj, sourceVisual, targetVisual, style, route) {
    var conn;
    if (!relObj || !sourceVisual || !targetVisual) {
      return null;
    }
    try {
      conn = view.add(relObj, sourceVisual, targetVisual);
      setVisualStyle(conn, style || STYLE.connection);
      if (route && conn.setAbsoluteRoute) {
        conn.setAbsoluteRoute(route);
      }
      return conn;
    } catch (error) {
      console.warn("Could not add connection " + relObj.name + " - " + String(error && error.message ? error.message : error));
      return null;
    }
  }

  var STYLE = {
    group: { fillColor: "#f6f8fb", lineColor: "#6b7280", fontColor: "#111827", opacity: 235 },
    groupBlue: { fillColor: "#dce9f9", lineColor: "#2a6cc4", fontColor: "#15395f", opacity: 235 },
    groupGreen: { fillColor: "#e3f4df", lineColor: "#4f8f3a", fontColor: "#1f4c1f", opacity: 235 },
    groupPurple: { fillColor: "#e9e3ff", lineColor: "#6a4fb3", fontColor: "#2f245c", opacity: 235 },
    groupRed: { fillColor: "#fde2e2", lineColor: "#b45353", fontColor: "#5b1f1f", opacity: 235 },
    groupYellow: { fillColor: "#fff4cc", lineColor: "#c08700", fontColor: "#5c3b00", opacity: 235 },
    note: { fillColor: "#fff8d8", lineColor: "#b99000", fontColor: "#2f2f2f", opacity: 245 },
    riskNote: { fillColor: "#fde2e2", lineColor: "#b45353", fontColor: "#5b1f1f", opacity: 245 },
    okNote: { fillColor: "#e3f4df", lineColor: "#4f8f3a", fontColor: "#1f4c1f", opacity: 245 },
    strategy: { fillColor: "#f5deaa", lineColor: "#8b6b2e", fontColor: "#332400" },
    business: { fillColor: "#ffffb5", lineColor: "#8b8b2e", fontColor: "#333300" },
    application: { fillColor: "#b5ffff", lineColor: "#2a7777", fontColor: "#003333" },
    technology: { fillColor: "#c9e7b7", lineColor: "#4f7a3a", fontColor: "#1d3614" },
    motivation: { fillColor: "#ccccff", lineColor: "#5f5fb3", fontColor: "#20205a" },
    implementation: { fillColor: "#ffe0e0", lineColor: "#b45353", fontColor: "#5b1f1f" },
    data: { fillColor: "#e6f7ff", lineColor: "#31708f", fontColor: "#123949" },
    source: { fillColor: "#f3f4f6", lineColor: "#4b5563", fontColor: "#111827" },
    connection: { lineColor: "#5b6f8f" },
    flow: { lineColor: "#2f6f9f" },
    risk: { lineColor: "#a94442" },
    good: { lineColor: "#3c763d" },
    dependency: { lineColor: "#6b7280" }
  };

  var ELEMENT_DEFS = [
  {
    "key": "st_enterprise_architect",
    "type": "stakeholder",
    "name": "Enterprise Architect / Modeler",
    "documentation": "Primary user who creates, reviews, and maintains ArchiMate models in a browser-local workspace.",
    "properties": {
      "Layer": "Motivation",
      "Concern": "Model authoring, governance, portability",
      "Persona": "Primary"
    }
  },
  {
    "key": "st_model_consumer",
    "type": "stakeholder",
    "name": "Model Consumer",
    "documentation": "Reader of published or shared architecture views; consumes model output without necessarily editing the source model.",
    "properties": {
      "Layer": "Motivation",
      "Concern": "Understand architecture decisions and views",
      "Persona": "Consumer"
    }
  },
  {
    "key": "st_extension_developer",
    "type": "stakeholder",
    "name": "Extension Developer",
    "documentation": "Developer who adds browser-local plugins, commands, panels, and workflow helpers through the Extension API.",
    "properties": {
      "Layer": "Motivation",
      "Concern": "Extensibility and safe local automation",
      "Persona": "Builder"
    }
  },
  {
    "key": "st_ai_agent",
    "type": "stakeholder",
    "name": "AI Coding Agent",
    "documentation": "Automation participant that can generate scripts, model fragments, documentation, tests, and extension code from architecture intent.",
    "properties": {
      "Layer": "Motivation",
      "Concern": "Agent-friendly automation surface",
      "Persona": "Automation"
    }
  },
  {
    "key": "st_maintainer",
    "type": "stakeholder",
    "name": "Project Maintainer",
    "documentation": "Maintainer responsible for code quality, compatibility, documentation, CI, and release readiness.",
    "properties": {
      "Layer": "Motivation",
      "Concern": "Maintainability, compatibility, publication",
      "Persona": "Owner"
    }
  },
  {
    "key": "st_security_reviewer",
    "type": "stakeholder",
    "name": "Security Reviewer",
    "documentation": "Reviewer focused on trusted local code, browser profile scope, package import trust, and absence of backend exposure.",
    "properties": {
      "Layer": "Motivation",
      "Concern": "Trust model, local execution, browser storage",
      "Persona": "Assurance"
    }
  },
  {
    "key": "role_modeler",
    "type": "business-role",
    "name": "Model Author",
    "documentation": "Role that opens, edits, validates, scripts, and exports ArchiMate models.",
    "properties": {
      "Layer": "Business",
      "Responsibility": "Author and maintain architecture models"
    }
  },
  {
    "key": "role_reader",
    "type": "business-role",
    "name": "Architecture Reader",
    "documentation": "Role that navigates diagrams, presentation mode, exported images, shared links, or published documentation.",
    "properties": {
      "Layer": "Business",
      "Responsibility": "Consume architecture information"
    }
  },
  {
    "key": "role_contributor",
    "type": "business-role",
    "name": "Repository Contributor",
    "documentation": "Role that edits source, tests, wiki pages, extension examples, and build scripts in the repository.",
    "properties": {
      "Layer": "Business",
      "Responsibility": "Improve product and docs"
    }
  },
  {
    "key": "actor_mixed_tool_team",
    "type": "business-actor",
    "name": "Mixed Archi / Browser Modeling Team",
    "documentation": "Team using both desktop Archi and Archi Online, relying on native .archimate round-trip compatibility.",
    "properties": {
      "Layer": "Business",
      "Collaboration Pattern": "Desktop and browser model interchange"
    }
  },
  {
    "key": "actor_local_browser_user",
    "type": "business-actor",
    "name": "Local Browser User",
    "documentation": "Human user running the application in their own browser profile, with models, settings, scripts, autosave, and extensions stored locally.",
    "properties": {
      "Layer": "Business",
      "Trust Boundary": "Browser profile"
    }
  },
  {
    "key": "vs_open_model",
    "type": "value-stream",
    "name": "Open or Create Model",
    "documentation": "Start from a new model, a native .archimate file, an Open Exchange file, autosave recovery, or an example/share link.",
    "properties": {
