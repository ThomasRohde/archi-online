  var VIEW_NAMES = [
    "AOA-00 Cover and Navigation",
    "AOA-01 Enterprise Context",
    "AOA-02 User Journey and Services",
    "AOA-03 Application Decomposition",
    "AOA-04 Scripting and Extension Runtime",
    "AOA-05 Model Core and Persistence",
    "AOA-06 Deployment and DevOps",
    "AOA-07 Compatibility and Interchange",
    "AOA-08 Quality Security and Trust",
    "AOA-09 Source Code Organization",
    "AOA-10 Implementation Roadmap"
  ];

  model.purpose = "Archi Online architecture model generated from public repository documentation and jArchi-compatible scripting conventions. It documents context, capabilities, application decomposition, data flow, deployment, compatibility, quality concerns, source organization, and implementation work packages.";
  model.prop("AO Architecture Subject", "Archi Online");
  model.prop("AO Architecture Scope", "Browser-only ArchiMate modeling application, jArchi-compatible scripting, extensions, native .archimate interoperability, local-first persistence, static deployment, and docs-as-code.");
  model.prop("AO Architecture Repository", SOURCE_REPOSITORY);
  model.prop("AO Architecture Generated By", SCRIPT_ID);
  model.prop("AO Architecture Generated At", GENERATED_AT);
  model.prop("AO Architecture Current Caveat", "Deployment and collaboration roadmap items are modelled as current capabilities only where documented; candidate future collaboration is explicitly marked as a gap.");

  var E = {};
  var R = {};
  var i;

  for (i = 0; i < ELEMENT_DEFS.length; i++) {
    E[ELEMENT_DEFS[i].key] = ensureElement(ELEMENT_DEFS[i]);
  }
  for (i = 0; i < RELATIONSHIP_DEFS.length; i++) {
    R[RELATIONSHIP_DEFS[i].key] = ensureRelationship(RELATIONSHIP_DEFS[i], E);
  }

  purgeGeneratedViews(VIEW_NAMES);

  function viewCover() {
    var v = createView("AOA-00 Cover and Navigation", "Generated cover view for the Archi Online architecture model. Use it as an index into the major concerns documented by this script.", {"Audience":"All stakeholders", "Viewpoint":"Overview", "Concern":"Orientation"});
