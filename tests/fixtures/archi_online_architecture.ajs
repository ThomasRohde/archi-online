    }
  },
  {
    "key": "proc_scripted_generation",
    "type": "business-process",
    "name": "Scripted Model Generation Workflow",
    "documentation": "Workflow where a user or AI-generated .ajs script creates elements, relationships, views, metadata, and documentation in one undoable run.",
    "properties": {
      "Layer": "Business",
      "Workflow": "Automation"
    }
  },
  {
    "key": "proc_extension_installation",
    "type": "business-process",
    "name": "Extension Installation Workflow",
    "documentation": "Workflow for importing, trusting, enabling, disabling, exporting, and reloading browser-local extension packages.",
    "properties": {
      "Layer": "Business",
      "Workflow": "Extensibility"
    }
  },
  {
    "key": "proc_docs_publishing",
    "type": "business-process",
    "name": "Documentation Publishing Workflow",
    "documentation": "Workflow for editing wiki source, validating links, building documentation, and publishing reviewed architecture documentation.",
    "properties": {
