  },
  {
    "key": "goal_low_cost_publish",
    "type": "goal",
    "name": "Keep deployment low-cost and simple",
    "documentation": "Use static build artifacts and documentation pipelines instead of server infrastructure for the core product.",
    "properties": {
      "Layer": "Motivation",
      "Goal Area": "Deployment"
    }
  },
  {
    "key": "goal_trusted_local",
    "type": "goal",
    "name": "Keep trust boundaries explicit",
    "documentation": "Make scripts and extensions powerful but local and trusted, with clear warnings where imported code can affect models or browser data.",
    "properties": {
      "Layer": "Motivation",
      "Goal Area": "Security"
    }
  },
  {
    "key": "outcome_productivity",
    "type": "outcome",
    "name": "Faster architecture model production",
    "documentation": "Modelers and agents can generate reusable model structure, relationships, and views quickly through scripts.",
    "properties": {
      "Layer": "Motivation",
      "Outcome Type": "Productivity"
    }
  },
  {
    "key": "outcome_interoperable_files",
    "type": "outcome",
    "name": "Interoperable ArchiMate files",
    "documentation": "Teams can exchange .archimate, Open Exchange XML, and CSV data while retaining semantics and properties where supported.",
    "properties": {
      "Layer": "Motivation",
      "Outcome Type": "Interoperability"
    }
  },
  {
    "key": "outcome_accessible_modeling",
    "type": "outcome",
    "name": "Accessible modeling workspace",
    "documentation": "Users get a modeling workspace from a URL or installed PWA, with local files and autosave protection.",
    "properties": {
      "Layer": "Motivation",
      "Outcome Type": "Adoption"
    }
  },
  {
    "key": "req_archimate32",
    "type": "requirement",
    "name": "Support full ArchiMate 3.2 metamodel",
    "documentation": "Support every ArchiMate 3.2 element and relationship type across the standard layers plus junctions.",
    "properties": {
      "Layer": "Motivation",
      "Requirement Type": "Functional"
    }
  },
  {
    "key": "req_relationship_matrix",
    "type": "requirement",
    "name": "Use official allowed-relationship matrix",
    "documentation": "Relationship creation and magic connector suggestions must follow Archi's allowed-relationship data.",
    "properties": {
      "Layer": "Motivation",
      "Requirement Type": "Correctness"
    }
  },
  {
    "key": "req_single_undo",
    "type": "requirement",
    "name": "Script run is one undo step",
    "documentation": "A script-generated model mutation set must be undoable as a single transaction.",
    "properties": {
      "Layer": "Motivation",
      "Requirement Type": "Usability"
    }
  },
  {
    "key": "req_no_backend",
    "type": "requirement",
    "name": "No backend runtime dependency",
    "documentation": "Core model authoring, persistence, scripting, and extensions run in the browser without server-side application logic.",
    "properties": {
      "Layer": "Motivation",
      "Requirement Type": "Architecture"
    }
  },
  {
    "key": "req_docs_reviewed",
    "type": "requirement",
    "name": "Documentation changes are reviewed like code",
    "documentation": "Wiki source is kept in the repository, checked, and published through documented helper commands.",
    "properties": {
      "Layer": "Motivation",
      "Requirement Type": "Governance"
    }
  },
  {
    "key": "constraint_browser_profile",
    "type": "constraint",
    "name": "Browser profile is the persistence boundary",
    "documentation": "Autosave, scripts, settings, extensions, layout, and extension storage are scoped to the local browser profile.",
    "properties": {
      "Layer": "Motivation",
      "Constraint Type": "Runtime"
    }
  },
  {
    "key": "constraint_sketch_canvas",
    "type": "constraint",
    "name": "Desktop Sketch and Canvas views are out of scope",
    "documentation": "Desktop Archi sketch/canvas extras are not modeled and should be treated as a compatibility limitation.",
    "properties": {
      "Layer": "Motivation",
      "Constraint Type": "Compatibility"
    }
  },
  {
    "key": "constraint_trusted_code",
    "type": "constraint",
    "name": "Scripts and extensions are trusted local code",
    "documentation": "Imported scripts and extension packages can affect the current model and browser profile; only trusted sources should be used.",
    "properties": {
      "Layer": "Motivation",
      "Constraint Type": "Security"
    }
  },
  {
    "key": "principle_archi_fidelity",
    "type": "principle",
    "name": "Fidelity to desktop Archi is the specification",
    "documentation": "When behavior overlaps with desktop Archi, compatibility data, relationships, figures, colors, validators, and file behavior should match Archi.",
    "properties": {
      "Layer": "Motivation",
      "Principle Type": "Compatibility"
    }
  },
  {
    "key": "principle_ops_mutations",
    "type": "principle",
    "name": "All model mutations go through operations",
    "documentation": "Model changes should flow through model operations and transactions to preserve undo/redo, dirty tracking, and consistency.",
    "properties": {
      "Layer": "Motivation",
      "Principle Type": "State management"
    }
  },
  {
    "key": "principle_pure_core",
    "type": "principle",
    "name": "Domain core is React-free",
    "documentation": "Model and scripting code remain portable and testable by avoiding React dependencies in the core domain and scripting layers.",
    "properties": {
      "Layer": "Motivation",
      "Principle Type": "Separation of concerns"
    }
  },
  {
    "key": "assessment_trust",
    "type": "assessment",
    "name": "Trusted-code risk is accepted locally",
    "documentation": "The product favors powerful local automation over sandboxing; risk is mitigated by local scope and explicit trust guidance.",
    "properties": {
      "Layer": "Motivation",
      "Assessment Type": "Security"
    }
  },
  {
    "key": "assessment_autosave",
    "type": "assessment",
    "name": "Autosave protects against local interruption only",
    "documentation": "IndexedDB autosave is useful crash protection but not a backup or team repository.",
    "properties": {
      "Layer": "Motivation",
      "Assessment Type": "Resilience"
    }
  },
  {
    "key": "assessment_static",
    "type": "assessment",
    "name": "Static delivery minimizes operating cost",
    "documentation": "A static SPA and documentation site reduce deployment complexity, but shared collaboration would require separate services if added later.",
    "properties": {
      "Layer": "Motivation",
      "Assessment Type": "Operational"
    }
  },
