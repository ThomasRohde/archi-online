<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="Archi Online Capability Model" id="id-archi-online-capability-model" version="5.0.0">
  <folder name="Strategy" id="id-folder-strategy" type="strategy"/>
  <folder name="Business" id="id-folder-business" type="business">
    <element xsi:type="archimate:BusinessService" name="ArchiMate modeling service" id="id-el-modeling-service">
      <documentation>The user-facing capability for authoring and maintaining ArchiMate models.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Model review service" id="id-el-review-service">
      <documentation>The user-facing capability for opening a shared model as a read-only review surface.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Author model" id="id-el-author-process">
      <documentation>Create, edit, script, layout, and save an architecture model.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Share model" id="id-el-share-process">
      <documentation>Generate a share URL and, when needed, publish the serialized model to GitHub Gist.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Inspect shared model" id="id-el-review-process">
      <documentation>Open a viewer link, select views, pan and zoom, and inspect properties without editing the shared model.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Open copy for editing" id="id-el-copy-process">
      <documentation>Clone a read-only shared model into a normal editor session.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Architecture model" id="id-el-architecture-model">
      <documentation>The conceptual model being edited and reviewed.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Review link" id="id-el-review-link">
      <documentation>A URL containing an inline fragment, gist id, or raw GitHub model URL.</documentation>
    </element>
  </folder>
  <folder name="Application" id="id-folder-application" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="Archi Online SPA" id="id-el-spa">
      <documentation>The React/Vite browser application containing the editor, viewer, persistence, scripting, and extension surfaces.</documentation>
      <property key="layer">
        <value>application shell</value>
      </property>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="App runtime boot" id="id-el-runtime-boot">
      <documentation>Chooses editor or viewer mode from URL state and hydrates only the stores required for that mode.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Docked editor shell" id="id-el-app-shell">
      <documentation>Normal editable application shell with toolbar, dock layout, model tree, canvas views, properties, scripting, settings, and extensions.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Read-only viewer shell" id="id-el-viewer-shell">
      <documentation>Lightweight shell for shared models with source label, view picker, canvas, properties, and open-copy action.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Toolbar and share command" id="id-el-toolbar">
      <documentation>Creates new models, opens/saves files, and runs the share flow with inline or gist-backed links.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="SVG view editor" id="id-el-view-editor">
      <documentation>Renders ArchiMate views on SVG, including editable interactions in editor mode and pan/zoom inspection in read-only mode.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Properties panel" id="id-el-properties-panel">
      <documentation>Shows concept metadata and edits properties in normal mode while hiding mutating controls in read-only mode.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Model tree" id="id-el-model-tree">
      <documentation>Navigates model folders, elements, relationships, and views.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Normalized model store" id="id-el-model-store">
      <documentation>Zustand store for ModelState, selection, active view, tools, dirty state, undo/redo, and read-only mode.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Transaction and undo/redo operations" id="id-el-undo-redo">
      <documentation>Routes model mutations through transactions so UI, scripting, and undo/redo stay consistent.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="ArchiMate XML I/O" id="id-el-xml-io">
      <documentation>Parser and serializer for Archi native .archimate XML.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Share encoding module" id="id-el-share-encoding">
      <documentation>Compresses inline share payloads, parses fragments, loads shared models, and remembers gist associations.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="GitHub Gist persistence module" id="id-el-github-persistence">
      <documentation>Creates, updates, and reads GitHub Gists and raw GitHub model URLs.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="File persistence module" id="id-el-file-persistence">
      <documentation>Uses File System Access and download fallback for opening and saving .archimate files.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="IndexedDB autosave" id="id-el-autosave">
      <documentation>Stores and restores editor workspaces, but is deliberately skipped while booting shared viewer links.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Settings store" id="id-el-settings-store">
      <documentation>Persists canvas, layout, and behavior preferences.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Extension runtime" id="id-el-extension-runtime">
      <documentation>Loads extension packages, exposes commands, panels, context menus, and app events.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="jArchi script runner" id="id-el-script-runner">
      <documentation>Executes scripts against the model API and reports console output.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Monaco script editor" id="id-el-monaco-editor">
      <documentation>Provides the browser code editor used by scripting and extension source editing.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="ELK layout extension" id="id-el-elk-extension">
      <documentation>Example extension applying ELK layout to model views.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Browser model editing" id="id-el-model-editing-app-service">
      <documentation>Application service exposed by the editor shell.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Read-only model viewing" id="id-el-viewer-app-service">
      <documentation>Application service exposed by the viewer shell.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Share link generation" id="id-el-share-app-service">
      <documentation>Application service that produces inline, gist-backed, or raw-source viewer links.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Gist publication" id="id-el-gist-app-service">
      <documentation>Application service that stores large shared models in GitHub Gist.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="XML import/export" id="id-el-xml-app-service">
      <documentation>Application service for Archi native file interchange.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Extension API" id="id-el-extension-app-service">
      <documentation>Application service consumed by local extensions and future automation.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="jArchi-compatible scripting" id="id-el-scripting-app-service">
      <documentation>Application service for executing scripts against the current model.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="ModelState graph" id="id-el-model-state">
      <documentation>Normalized in-memory model: folders, concepts, views, nodes, connections, and model metadata.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name=".archimate XML document" id="id-el-archimate-xml">
      <documentation>Serialized Archi native XML used by disk persistence, gist sharing, and raw URL loading.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Compressed inline share payload" id="id-el-inline-payload">
      <documentation>Deflated XML encoded as base64url in the URL fragment.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Gist-backed viewer link" id="id-el-gist-link-data">
      <documentation>Viewer URL containing #gist=&lt;id&gt; for a model stored in GitHub Gist.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Raw GitHub model URL" id="id-el-raw-url-data">
      <documentation>Viewer URL containing #raw=&lt;url&gt; that points at GitHub raw content.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="IndexedDB workspace" id="id-el-workspace-data">
      <documentation>Autosave, settings, token, and gist association records stored in browser IndexedDB.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Local .archimate file" id="id-el-local-file-data">
      <documentation>A file selected through File System Access or downloaded from the app.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Extension package" id="id-el-extension-package-data">
      <documentation>Extension source or package manifest and files.</documentation>
    </element>
  </folder>
  <folder name="Technology &amp; Physical" id="id-folder-technology" type="technology">
    <element xsi:type="archimate:Node" name="Browser runtime" id="id-el-browser-runtime">
      <documentation>Modern browser executing the SPA and providing DOM, Clipboard, File System Access, and IndexedDB APIs.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="Static web host" id="id-el-static-host">
      <documentation>Hosts the built Vite assets for Archi Online.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="GitHub platform" id="id-el-github-platform">
      <documentation>External platform providing Gist and raw content endpoints.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="User workstation" id="id-el-local-device">
      <documentation>The device running the browser and holding local files.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="React" id="id-el-react-runtime">
      <documentation>UI runtime used by the app shells, panels, and dialogs.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Vite build" id="id-el-vite-build">
      <documentation>Development server and production bundler for the browser app.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="TypeScript" id="id-el-typescript">
      <documentation>Strict TypeScript source layer for application and model behavior.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Monaco Editor" id="id-el-monaco-lib">
      <documentation>Browser code editor library.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="ELK.js" id="id-el-elk-lib">
      <documentation>Graph layout engine used by extension functionality.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="fflate" id="id-el-fflate-lib">
      <documentation>Compression library used for inline share payloads.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="idb-keyval" id="id-el-idb-keyval-lib">
      <documentation>Small key-value wrapper around IndexedDB.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyService" name="GitHub Gist API" id="id-el-gist-api">
      <documentation>api.github.com/gists create, update, and metadata read endpoints.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyService" name="GitHub raw content" id="id-el-raw-content">
      <documentation>gist.githubusercontent.com and raw.githubusercontent.com model file reads.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyService" name="File System Access API" id="id-el-filesystem-api">
      <documentation>Browser API for opening and saving local model files when available.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyService" name="IndexedDB API" id="id-el-indexeddb-api">
      <documentation>Browser database used by autosave, settings, token, and gist association stores.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyService" name="Clipboard API" id="id-el-clipboard-api">
      <documentation>Browser API used to place share links on the clipboard.</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="Production static assets" id="id-el-static-assets">
      <documentation>Built HTML, CSS, JavaScript, workers, Monaco assets, and ELK bundle.</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="Gist .archimate file" id="id-el-gist-file-artifact">
      <documentation>The .archimate file stored inside a GitHub Gist.</documentation>
    </element>
  </folder>
  <folder name="Motivation" id="id-folder-motivation" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Enterprise Architect" id="id-el-enterprise-architect">
      <documentation>Owns model quality and uses Archi Online to inspect, edit, and share ArchiMate models.</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Model Author" id="id-el-model-author">
      <documentation>Creates and edits models in the browser, then shares links for review.</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Model Reviewer" id="id-el-reviewer">
      <documentation>Opens shared models without installing Archi or receiving editable files.</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Extension Developer" id="id-el-extension-developer">
      <documentation>Adds local extensions and scripts through the app extension surface.</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="Browser-first enterprise modeling" id="id-el-browser-first-driver">
      <documentation>Architecture work should be possible from a modern browser without a desktop Archi install.</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="Fast model review loops" id="id-el-review-driver">
      <documentation>Sharing a model should be as easy as sending a link while preserving model fidelity.</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="Long inline links are fragile" id="id-el-url-risk">
      <documentation>Real models exceed practical URL limits in browsers, chat clients, and email tools.</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="Edit ArchiMate models in the browser" id="id-el-edit-goal">
      <documentation>Provide a usable browser modeler with canvas editing, properties, persistence, and scripting.</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="Share models for review" id="id-el-share-goal">
      <documentation>Create a link that opens the same model in read-only mode.</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="Keep review links read-only" id="id-el-readonly-goal">
      <documentation>Reviewers can inspect the model and open an editable copy, but the shared source is never mutated by viewing.</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="Preserve Archi .archimate fidelity" id="id-el-fidelity-goal">
      <documentation>Import, edit, serialize, and round-trip Archi native XML without losing structure relevant to this app.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="URL and gist share links" id="id-el-share-links-req">
      <documentation>Small models use compressed fragments; larger models publish a .archimate file to GitHub Gist.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="Zero-auth viewer loading" id="id-el-zero-auth-req">
      <documentation>Public and secret gist links, plus GitHub raw URLs, open in the viewer without requiring a GitHub token.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="Open shared model as editable copy" id="id-el-copy-req">
      <documentation>The viewer can switch into the full editor with a cloned model and autosave restore disabled for that transition.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="GitHub token stays local" id="id-el-token-req">
      <documentation>The gist token is stored in local IndexedDB key-value storage and is only sent to api.github.com.</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="Reuse gist per model id" id="id-el-gist-reuse-req">
      <documentation>Re-sharing a model updates the remembered gist id for the same model.info.id.</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="Native .archimate remains source of truth" id="id-el-native-file-principle">
      <documentation>Sharing and persistence are wrappers around the same ArchiMate XML model, not a separate export format.</documentation>
    </element>
  </folder>
  <folder name="Implementation &amp; Migration" id="id-folder-implementation_migration" type="implementation_migration">
    <element xsi:type="archimate:WorkPackage" name="Milestone 1 model sharing" id="id-el-m1-sharing">
      <documentation>Implemented read-only viewer links, inline payloads, GitHub gist-backed links, public raw loading, and open-copy editing.</documentation>
    </element>
    <element xsi:type="archimate:Deliverable" name="Read-only viewer and gist sharing" id="id-el-m1-deliverable">
      <documentation>The shipped capability under test with this model.</documentation>
    </element>
  </folder>
  <folder name="Other" id="id-folder-other" type="other"/>
  <folder name="Relations" id="id-folder-relations" type="relations">
    <element xsi:type="archimate:InfluenceRelationship" name="+" id="id-rel-author-influences-edit" source="id-el-model-author" target="id-el-edit-goal">
      <documentation>Model authors motivate browser-based editing.</documentation>
    </element>
    <element xsi:type="archimate:InfluenceRelationship" name="+" id="id-rel-reviewer-influences-share" source="id-el-reviewer" target="id-el-share-goal">
      <documentation>Reviewers motivate link-based sharing.</documentation>
    </element>
    <element xsi:type="archimate:InfluenceRelationship" name="+" id="id-rel-architect-influences-fidelity" source="id-el-enterprise-architect" target="id-el-fidelity-goal">
      <documentation>Enterprise architects need model fidelity.</documentation>
    </element>
    <element xsi:type="archimate:InfluenceRelationship" name="++" id="id-rel-browser-driver-influences-edit" source="id-el-browser-first-driver" target="id-el-edit-goal">
      <documentation>Browser-first work strongly drives the editing goal.</documentation>
    </element>
    <element xsi:type="archimate:InfluenceRelationship" name="++" id="id-rel-review-driver-influences-share" source="id-el-review-driver" target="id-el-share-goal">
      <documentation>Fast review loops strongly drive share links.</documentation>
    </element>
    <element xsi:type="archimate:InfluenceRelationship" name="++" id="id-rel-url-risk-influences-gist" source="id-el-url-risk" target="id-el-share-links-req">
      <documentation>The URL risk drives gist-backed fallback.</documentation>
    </element>
    <element xsi:type="archimate:RealizationRelationship" name="realizes" id="id-rel-share-realizes-review" source="id-el-share-links-req" target="id-el-share-goal">
      <documentation>Share link requirement realizes the share goal.</documentation>
    </element>
    <element xsi:type="archimate:RealizationRelationship" name="realizes" id="id-rel-zero-auth-realizes-share" source="id-el-zero-auth-req" target="id-el-share-goal">
      <documentation>Zero-auth opening realizes practical model review.</documentation>
    </element>
    <element xsi:type="archimate:RealizationRelationship" name="realizes" id="id-rel-copy-realizes-readonly" source="id-el-copy-req" target="id-el-readonly-goal">
      <documentation>Open-copy editing keeps review links read-only.</documentation>
    </element>
    <element xsi:type="archimate:RealizationRelationship" name="supports" id="id-rel-token-realizes-security" source="id-el-token-req" target="id-el-readonly-goal">
      <documentation>Local token storage avoids embedding credentials in links.</documentation>
    </element>
    <element xsi:type="archimate:RealizationRelationship" name="supports" id="id-rel-reuse-realizes-share" source="id-el-gist-reuse-req" target="id-el-share-goal">
      <documentation>Stable gist reuse keeps shared URLs durable.</documentation>
    </element>
    <element xsi:type="archimate:InfluenceRelationship" name="+" id="id-rel-principle-influences-fidelity" source="id-el-native-file-principle" target="id-el-fidelity-goal">
      <documentation>The native-file principle supports fidelity.</documentation>
    </element>
    <element xsi:type="archimate:AssignmentRelationship" name="performs" id="id-rel-author-assigned-author" source="id-el-model-author" target="id-el-author-process">
      <documentation>Model author performs the authoring process.</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="updates" id="id-rel-author-process-accesses-model" source="id-el-author-process" target="id-el-architecture-model" accessType="3">
      <documentation>Authoring updates the architecture model.</documentation>
    </element>
    <element xsi:type="archimate:TriggeringRelationship" name="then shares" id="id-rel-author-triggers-share" source="id-el-author-process" target="id-el-share-process">
      <documentation>The author shares after editing.</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="serializes" id="id-rel-share-accesses-model" source="id-el-share-process" target="id-el-architecture-model" accessType="1">
      <documentation>Sharing reads the current model.</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="writes" id="id-rel-share-creates-link" source="id-el-share-process" target="id-el-review-link" accessType="0">
      <documentation>Sharing writes a review link.</documentation>
    </element>
    <element xsi:type="archimate:AssignmentRelationship" name="performs" id="id-rel-reviewer-assigned-review" source="id-el-reviewer" target="id-el-review-process">
      <documentation>Reviewer performs the inspection process.</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="opens" id="id-rel-review-reads-link" source="id-el-review-process" target="id-el-review-link" accessType="1">
      <documentation>Review process reads the shared link.</documentation>
    </element>
    <element xsi:type="archimate:AccessRelationship" name="inspects" id="id-rel-review-reads-model" source="id-el-review-process" target="id-el-architecture-model" accessType="1">
      <documentation>Review process reads the architecture model.</documentation>
    </element>
    <element xsi:type="archimate:TriggeringRelationship" name="optional copy" id="id-rel-review-triggers-copy" source="id-el-review-process" target="id-el-copy-process">
      <documentation>The reviewer can open a copy for editing.</documentation>
    </element>
    <element xsi:type="archimate:ServingRelationship" name="supports" id="id-rel-modeling-serves-author" source="id-el-modeling-service" target="id-el-author-process">
      <documentation>Modeling service serves authoring.</documentation>
    </element>
    <element xsi:type="archimate:ServingRelationship" name="supports" id="id-rel-review-serves-review" source="id-el-review-service" target="id-el-review-process">
      <documentation>Review service serves inspection.</documentation>
    </element>
    <element xsi:type="archimate:CompositionRelationship" name="contains" id="id-rel-spa-composes-runtime" source="id-el-spa" target="id-el-runtime-boot">
      <documentation>SPA contains runtime boot.</documentation>
    </element>
    <element xsi:type="archimate:CompositionRelationship" name="contains" id="id-rel-spa-composes-app-shell" source="id-el-spa" target="id-el-app-shell">
      <documentation>SPA contains editable shell.</documentation>
    </element>
    <element xsi:type="archimate:CompositionRelationship" name="contains" id="id-rel-spa-composes-viewer-shell" source="id-el-spa" target="id-el-viewer-shell">
      <documentation>SPA contains viewer shell.</documentation>
    </element>
    <element xsi:type="archimate:CompositionRelationship" name="contains" id="id-rel-app-shell-composes-toolbar" source="id-el-app-shell" target="id-el-toolbar">
      <documentation>App shell contains toolbar.</documentation>
    </element>
    <element xsi:type="archimate:CompositionRelationship" name="contains" id="id-rel-app-shell-composes-tree" source="id-el-app-shell" target="id-el-model-tree">
      <documentation>App shell contains model tree.</documentation>
    </element>
    <element xsi:type="archimate:CompositionRelationship" name="contains" id="id-rel-app-shell-composes-editor" source="id-el-app-shell" target="id-el-view-editor">
      <documentation>App shell contains view editor panels.</documentation>
    </element>
    <element xsi:type="archimate:CompositionRelationship" name="contains" id="id-rel-app-shell-composes-props" source="id-el-app-shell" target="id-el-properties-panel">
      <documentation>App shell contains properties panel.</documentation>
    </element>
    <element xsi:type="archimate:CompositionRelationship" name="contains readonly" id="id-rel-viewer-composes-editor" source="id-el-viewer-shell" target="id-el-view-editor">
      <documentation>Viewer shell contains read-only view editor.</documentation>
    </element>
    <element xsi:type="archimate:CompositionRelationship" name="contains inspect" id="id-rel-viewer-composes-props" source="id-el-viewer-shell" target="id-el-properties-panel">
      <documentation>Viewer shell contains properties inspection.</documentation>
    </element>
    <element xsi:type="archimate:RealizationRelationship" name="realizes" id="id-rel-app-shell-realizes-editing-service" source="id-el-app-shell" target="id-el-model-editing-app-service">
      <documentation>Editable shell realizes browser model editing.</documentation>
    </element>
