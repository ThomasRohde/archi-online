{
  "name": "archi-online",
  "private": true,
  "version": "0.2.0",
  "description": "Web-based ArchiMate modeler inspired by Archi, scriptable with a jArchi-compatible JavaScript API",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "sync-versions": "node tools/sync-versions.mjs",
    "version": "node tools/sync-versions.mjs && git add extensions",
    "docs:check": "node tools/check-wiki-docs.mjs",
    "docs:publish-wiki": "node tools/publish-wiki.mjs",
    "security:audit": "npm audit",
    "ci:check": "node tools/sync-versions.mjs --check && npm run docs:check && npm run lint && npm run typecheck && npm test && npm run security:audit && npm run build"
  },
  "dependencies": {
    "dockview": "^7.0.2",
    "dockview-react": "^7.0.2",
    "elkjs": "^0.11.1",
    "fflate": "^0.8.3",
    "idb-keyval": "^6.2.1",
    "immer": "^10.1.1",
    "monaco-editor": "^0.55.1",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "overrides": {
    "dompurify": "3.4.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^25.0.1",
    "sharp": "^0.35.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1"
  }
}
