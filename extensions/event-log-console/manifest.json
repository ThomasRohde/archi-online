{
  "schemaVersion": 2,
  "id": "examples.event-log-console",
  "name": "Event Log Console",
  "version": "1.9.2",
  "description": "Records app, model, view, tree, and selection events from the extension event bridge.",
  "main": "main.js",
  "contributes": {
    "commands": [
      {
        "id": "examples.event-log-console.open",
        "title": "Open event log"
      },
      {
        "id": "examples.event-log-console.clear",
        "title": "Clear event log"
      }
    ],
    "menus": [
      {
        "id": "examples.event-log-console.menu.open",
        "label": "Open event log",
        "command": "examples.event-log-console.open",
        "location": "extensions.menu"
      }
    ],
    "panels": [
      {
        "id": "examples.event-log-console.panel",
        "title": "Event Log"
      }
    ],
    "events": [
      {
        "name": "app.ready"
      },
      {
        "name": "model.changed"
      },
      {
        "name": "selection.changed"
      }
    ]
  }
}
